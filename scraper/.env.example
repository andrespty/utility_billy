TALGOV_EMAIL=email
TALGOV_PASSWORD=password
ACCOUNT_NUMBER=account_number

# Needed by sync.py to upsert readings straight into Supabase. These are
# your app login credentials (the account you sign into the web app with),
# not a service-role key — see app/.env.example for SUPABASE_URL and the
# anon key (same values as VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_EMAIL=email
SUPABASE_PASSWORD=password
